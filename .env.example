DATABASE_URL=postgresql://admin:PASSWORD@127.0.0.1:5432/app_db # Direct connection string

# PostgreSQL — superuser (for administration only)
POSTGRES_CONTAINER_NAME=postgres_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# PostgreSQL — application database
APP_DB=app_db
APP_DB_USER=app_user
APP_DB_PASSWORD=CHANGE_ME

# PostgreSQL — n8n database
N8N_DB=n8n_db
N8N_DB_USER=n8n_user
N8N_DB_PASSWORD=CHANGE_ME

# Redis credentials
POSTGRES_CONTAINER_NAME=redis_cache
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME
REDIS_MAXMEMORY=256mb

# n8n
N8N_CONTAINER_NAME=n8n
N8N_PORT=5678
N8N_ENCRYPTION_KEY=CHANGE_ME_32_RANDOM_STRING
N8N_PASSWORD=CHANGE_ME
TIMEZONE=America/Sao_Paulo
